<resources xmlns:tools="http://schemas.android.com/tools">

    <style name="Base.Theme.LiftLog" parent="Theme.Material3.DayNight.NoActionBar">
        <!-- Accent-forward palette -->
        <item name="colorPrimary">@color/brand_accent</item>
        <item name="colorPrimaryDark">@color/brand_primary_dark</item>
        <item name="colorOnPrimary">@color/on_accent</item>
        <item name="colorPrimaryContainer">@color/accent_soft</item>
        <item name="colorOnPrimaryContainer">@color/text_primary</item>
        <item name="colorSecondary">@color/brand_primary</item>
        <item name="colorOnSecondary">@color/on_accent</item>
        <item name="colorSecondaryContainer">@color/accent_soft</item>
        <item name="colorOnSecondaryContainer">@color/text_primary</item>

        <!-- Surfaces read as frosted glass on the gradient backdrop -->
        <item name="android:windowBackground">@drawable/bg_app_gradient</item>
        <item name="colorSurface">@color/surface_glass</item>
        <item name="colorSurfaceVariant">@color/surface_glass_high</item>
        <item name="colorOnSurface">@color/text_primary</item>
        <item name="colorOnSurfaceVariant">@color/text_secondary</item>
        <item name="android:colorBackground">@color/bg_grad_top</item>
        <item name="colorOnBackground">@color/text_primary</item>
        <item name="colorOutline">@color/glass_stroke</item>
        <item name="colorOutlineVariant">@color/glass_stroke_soft</item>

        <!-- Text -->
        <item name="android:textColorPrimary">@color/text_primary</item>
        <item name="android:textColorSecondary">@color/text_secondary</item>
        <item name="android:textColorHint">@color/text_hint</item>

        <!-- Edge-to-edge so the aurora flows under the system bars -->
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:enforceStatusBarContrast" tools:targetApi="q">false</item>
        <item name="android:enforceNavigationBarContrast" tools:targetApi="q">false</item>

        <!-- Component defaults: everything inherits the glass look -->
        <item name="materialButtonStyle">@style/Widget.LiftLog.Button</item>
        <item name="materialButtonOutlinedStyle">@style/Widget.LiftLog.Button.Outlined</item>
        <item name="extendedFloatingActionButtonStyle">@style/Widget.LiftLog.FAB</item>
        <item name="floatingActionButtonStyle">@style/Widget.LiftLog.FAB.Regular</item>
        <item name="bottomNavigationStyle">@style/Widget.LiftLog.BottomNav</item>
        <item name="materialCardViewStyle">@style/Widget.LiftLog.Card</item>
    </style>

    <style name="Theme.LiftLog" parent="Base.Theme.LiftLog" />

    <!-- ============================================================= -->
    <!-- Component styles                                              -->
    <!-- ============================================================= -->

    <style name="ShapeAppearance.LiftLog.Pill" parent="">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">50%</item>
    </style>

    <!-- Filled / primary action: warm amber, rounded, sentence case -->
    <style name="Widget.LiftLog.Button" parent="Widget.Material3.Button">
        <item name="cornerRadius">18dp</item>
        <item name="android:paddingTop">14dp</item>
        <item name="android:paddingBottom">14dp</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:letterSpacing">0.01</item>
        <item name="android:textStyle">bold</item>
        <item name="backgroundTint">@color/brand_accent</item>
        <item name="android:textColor">@color/on_accent</item>
        <item name="iconTint">@color/on_accent</item>
        <item name="rippleColor">@color/glass_ripple</item>
        <item name="elevation">0dp</item>
    </style>

    <!-- Glass outline: faint translucent fill + bright hairline edge -->
    <style name="Widget.LiftLog.Button.Outlined" parent="Widget.Material3.Button.OutlinedButton">
        <item name="cornerRadius">18dp</item>
        <item name="android:paddingTop">14dp</item>
        <item name="android:paddingBottom">14dp</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:letterSpacing">0.01</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="iconTint">@color/text_primary</item>
        <item name="strokeColor">@color/glass_stroke</item>
        <item name="strokeWidth">1dp</item>
        <item name="backgroundTint">@color/glass_fill_soft</item>
        <item name="rippleColor">@color/glass_ripple</item>
    </style>

    <style name="Widget.LiftLog.FAB" parent="Widget.Material3.ExtendedFloatingActionButton.Icon.Primary">
        <item name="backgroundTint">@color/brand_accent</item>
        <item name="android:textColor">@color/on_accent</item>
        <item name="iconTint">@color/on_accent</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textAllCaps">false</item>
        <item name="shapeAppearanceOverlay">@style/ShapeAppearance.LiftLog.Pill</item>
        <item name="elevation">6dp</item>
    </style>

    <style name="Widget.LiftLog.FAB.Regular" parent="Widget.Material3.FloatingActionButton.Primary">
        <item name="backgroundTint">@color/brand_accent</item>
        <item name="tint">@color/on_accent</item>
        <item name="elevation">6dp</item>
    </style>

    <!-- Glass card (MaterialCardView default) -->
    <style name="Widget.LiftLog.Card" parent="Widget.Material3.CardView.Filled">
        <item name="cardBackgroundColor">@color/glass_card_solid</item>
        <item name="cardCornerRadius">22dp</item>
        <item name="cardElevation">0dp</item>
        <item name="strokeColor">@color/glass_stroke</item>
        <item name="strokeWidth">1dp</item>
    </style>

    <!-- Frosted bottom navigation -->
    <style name="Widget.LiftLog.BottomNav" parent="Widget.Material3.BottomNavigationView">
        <item name="android:background">@drawable/bg_glass_bar</item>
        <item name="itemIconTint">@color/nav_item_color</item>
        <item name="itemTextColor">@color/nav_item_color</item>
        <item name="itemActiveIndicatorStyle">@style/Widget.LiftLog.BottomNav.Indicator</item>
        <item name="elevation">0dp</item>
        <item name="itemRippleColor">@color/glass_ripple</item>
    </style>

    <style name="Widget.LiftLog.BottomNav.Indicator" parent="Widget.Material3.BottomNavigationView.ActiveIndicator">
        <item name="android:color">@color/accent_soft</item>
    </style>

</resources>
