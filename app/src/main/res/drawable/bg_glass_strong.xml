<?xml version="1.0" encoding="utf-8"?>
<!-- Highlighted glass panel for hero stats / results -->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">
    <corners android:radius="26dp" />
    <gradient
        android:type="linear"
        android:angle="305"
        android:startColor="@color/glass_fill_strong_top"
        android:endColor="@color/glass_fill_strong_bottom" />
    <stroke
        android:width="1dp"
        android:color="@color/glass_stroke" />
</shape>
