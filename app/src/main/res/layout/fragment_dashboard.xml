<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:id="@+id/text_greeting"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/dashboard_greeting"
                android:textAppearance="?attr/textAppearanceHeadlineSmall"
                android:textStyle="bold"
                android:paddingBottom="16dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/dashboard_last_workout"
                android:textAppearance="?attr/textAppearanceTitleMedium"
                android:paddingBottom="8dp" />

            <LinearLayout
                android:id="@+id/card_last_workout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_card"
                android:padding="16dp"
                android:layout_marginBottom="24dp">

                <TextView
                    android:id="@+id/text_last_workout"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/dashboard_no_workouts_yet"
                    android:textAppearance="?attr/textAppearanceBodyLarge" />
            </LinearLayout>

            <GridLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:columnCount="2"
                android:rowCount="2"
                android:useDefaultMargins="true">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_plans"
                    style="?attr/materialButtonOutlinedStyle"
                    android:layout_width="0dp"
                    android:layout_height="112dp"
                    android:layout_columnWeight="1"
                    android:layout_rowWeight="1"
                    android:text="@string/dashboard_plans"
                    app:icon="@drawable/ic_edit_24"
                    app:iconGravity="top"
                    app:iconTint="@color/brand_accent" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_history"
                    style="?attr/materialButtonOutlinedStyle"
                    android:layout_width="0dp"
                    android:layout_height="112dp"
                    android:layout_columnWeight="1"
                    android:layout_rowWeight="1"
                    android:text="@string/dashboard_history"
                    app:icon="@drawable/ic_history_24"
                    app:iconGravity="top"
                    app:iconTint="@color/brand_accent" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_library"
                    style="?attr/materialButtonOutlinedStyle"
                    android:layout_width="0dp"
                    android:layout_height="112dp"
                    android:layout_columnWeight="1"
                    android:layout_rowWeight="1"
                    android:text="@string/dashboard_library"
                    app:icon="@drawable/ic_library_24"
                    app:iconGravity="top"
                    app:iconTint="@color/brand_accent" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_one_rm"
                    style="?attr/materialButtonOutlinedStyle"
                    android:layout_width="0dp"
                    android:layout_height="112dp"
                    android:layout_columnWeight="1"
                    android:layout_rowWeight="1"
                    android:text="@string/dashboard_one_rm"
                    app:icon="@drawable/ic_calculator_24"
                    app:iconGravity="top"
                    app:iconTint="@color/brand_accent" />
            </GridLayout>
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <com.google.android.material.floatingactionbutton.ExtendedFloatingActionButton
        android:id="@+id/fab_quick_start"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|end"
        android:layout_margin="16dp"
        android:text="@string/dashboard_quick_start"
        app:icon="@drawable/ic_play_24" />

</androidx.coordinatorlayout.widget.CoordinatorLayout>
